PORT=3000
NODE_ENV=development
BASE_URL=https://your-public-domain.example.com
LOG_LEVEL=info

# Facebook / Meta app
FB_VERIFY_TOKEN=replace-with-random-verify-token
FB_APP_SECRET=replace-with-facebook-app-secret
FB_ACCESS_TOKEN=replace-with-system-user-or-page-access-token
FB_GRAPH_API_VERSION=v22.0

# Lead processing
DEFAULT_COUNTRY=US
REQUIRE_EXPLICIT_CONSENT=true
CONSENT_FIELD_KEYS=consent,opt_in,whatsapp_opt_in,privacy_consent,marketing_consent
CONSENT_TRUE_VALUES=true,yes,y,1,checked,on,consented
PHONE_FIELD_KEYS=phone,phone_number,mobile,mobile_phone,whatsapp,whatsapp_phone
FIRST_NAME_FIELD_KEYS=first_name,firstname,full_name,name
GROUP_INVITE_LINK=https://chat.whatsapp.com/replace-this-link
BUSINESS_OFFER_NAME=VIP Client Offer
META_FORM_NAMES_WITH_IMPLIED_CONSENT=

# WhatsApp Cloud API
WA_PHONE_NUMBER_ID=replace-with-whatsapp-phone-number-id
WA_ACCESS_TOKEN=replace-with-whatsapp-permanent-access-token
WA_API_VERSION=v22.0
WA_TEMPLATE_NAME=lead_group_invite_v1
WA_TEMPLATE_LANGUAGE_CODE=en_US

# Retry behavior
WHATSAPP_RETRY_ATTEMPTS=3
WHATSAPP_RETRY_DELAY_MS=1500

# Storage
LEADS_FILE_PATH=./data/leads.json
ENABLE_GOOGLE_SHEETS_LOGGING=false
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_WORKSHEET_NAME=LeadLog
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
